{
  "@context": {
    "@version": 1.1,
    "ambassador": "https://getambassador.io/ns/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",
    "k8s": "https://kubernetes.io/ns/",

    "Mapping": {
      "@id": "ambassador:Mapping",
      "@context": {
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "namespace": {
          "@id": "k8s:namespace",
          "@type": "xsd:string"
        },
        "hostname": {
          "@id": "ambassador:hostname",
          "@type": "xsd:string"
        },
        "prefix": {
          "@id": "ambassador:prefix",
          "@type": "xsd:string"
        },
        "service": {
          "@id": "ambassador:service",
          "@type": "xsd:string"
        },
        "rewrite": {
          "@id": "ambassador:rewrite",
          "@type": "xsd:string"
        },
        "method": {
          "@id": "ambassador:method",
          "@type": "xsd:string"
        },
        "timeoutMs": {
          "@id": "ambassador:timeoutMs",
          "@type": "xsd:integer"
        },
        "weight": {
          "@id": "ambassador:weight",
          "@type": "xsd:integer"
        },
        "grpc": {
          "@id": "ambassador:grpc",
          "@type": "xsd:boolean"
        },
        "bypassAuth": {
          "@id": "ambassador:bypassAuth",
          "@type": "xsd:boolean"
        },
        "labels": {
          "@id": "schema:keywords",
          "@container": "@set"
        },
        "state": {
          "@id": "ambassador:state",
          "@type": "xsd:string"
        },
        "createdAt": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Host": {
      "@id": "ambassador:Host",
      "@context": {
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "namespace": {
          "@id": "k8s:namespace",
          "@type": "xsd:string"
        },
        "hostname": {
          "@id": "ambassador:hostname",
          "@type": "xsd:string"
        },
        "tlsSecret": {
          "@id": "ambassador:tlsSecret",
          "@type": "xsd:string"
        },
        "tlsContext": {
          "@id": "ambassador:tlsContext",
          "@type": "@id"
        },
        "acmeProvider": {
          "@id": "ambassador:acmeProvider",
          "@type": "@id"
        },
        "insecureAction": {
          "@id": "ambassador:insecureAction",
          "@type": "xsd:string"
        },
        "state": {
          "@id": "ambassador:state",
          "@type": "xsd:string"
        },
        "tlsCertificateSource": {
          "@id": "ambassador:tlsCertificateSource",
          "@type": "xsd:string"
        },
        "createdAt": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        }
      }
    },

    "TLSContext": {
      "@id": "ambassador:TLSContext",
      "@context": {
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "namespace": {
          "@id": "k8s:namespace",
          "@type": "xsd:string"
        },
        "secret": {
          "@id": "ambassador:secret",
          "@type": "xsd:string"
        },
        "hosts": {
          "@id": "ambassador:hosts",
          "@container": "@set"
        },
        "minTlsVersion": {
          "@id": "ambassador:minTlsVersion",
          "@type": "xsd:string"
        },
        "maxTlsVersion": {
          "@id": "ambassador:maxTlsVersion",
          "@type": "xsd:string"
        },
        "certRequired": {
          "@id": "ambassador:certRequired",
          "@type": "xsd:boolean"
        },
        "cipherSuites": {
          "@id": "ambassador:cipherSuites",
          "@container": "@set"
        },
        "alpnProtocols": {
          "@id": "ambassador:alpnProtocols",
          "@type": "xsd:string"
        },
        "sni": {
          "@id": "ambassador:sni",
          "@type": "xsd:string"
        }
      }
    },

    "RateLimit": {
      "@id": "ambassador:RateLimit",
      "@context": {
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "namespace": {
          "@id": "k8s:namespace",
          "@type": "xsd:string"
        },
        "domain": {
          "@id": "ambassador:domain",
          "@type": "xsd:string"
        },
        "limits": {
          "@id": "ambassador:limits",
          "@container": "@set"
        },
        "rate": {
          "@id": "ambassador:rate",
          "@type": "xsd:integer"
        },
        "unit": {
          "@id": "ambassador:unit",
          "@type": "xsd:string"
        },
        "pattern": {
          "@id": "ambassador:pattern",
          "@container": "@set"
        },
        "createdAt": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Module": {
      "@id": "ambassador:Module",
      "@context": {
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "namespace": {
          "@id": "k8s:namespace",
          "@type": "xsd:string"
        },
        "config": {
          "@id": "ambassador:config"
        },
        "ambassadorId": {
          "@id": "ambassador:ambassadorId",
          "@container": "@set"
        }
      }
    }
  }
}

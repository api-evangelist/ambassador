{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "TLSContextSpec",
  "type": "object",
  "properties": {
    "hosts": {
      "type": "array"
    },
    "secret": {
      "type": "string"
    },
    "cert_chain_file": {
      "type": "string"
    },
    "private_key_file": {
      "type": "string"
    },
    "ca_secret": {
      "type": "string"
    },
    "cert_required": {
      "type": "boolean"
    },
    "min_tls_version": {
